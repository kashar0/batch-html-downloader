{
  "manifest_version": 3,
  "name": "Batch HTML Downloader Pro",
  "version": "2.0",
  "description": "Download numbered HTML files in batches with live progress, history, speed stats, and smart retry.",
  "permissions": ["downloads", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Batch HTML Downloader Pro"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none';"
  }
}
